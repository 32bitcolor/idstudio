# ─────────────────────────────────────────────────────────────────────────────
# IDStudio environment reference. Copy to `.env` and fill in real values.
#   cp .env.example .env
# Generate secrets with:  openssl rand -base64 32
# ─────────────────────────────────────────────────────────────────────────────

# ── App secrets (used in BOTH local dev and Docker) ──────────────────────────
# Signs session JWTs. MUST be a long random string. Change for production.
SESSION_SECRET=change-me-openssl-rand-base64-32

# ── Local development (running `npm run dev` directly on your machine) ────────
# Point at the Postgres you run locally (e.g. the compose `postgres` service
# published to localhost). Ignored when the whole stack runs under Compose.
DATABASE_URL=postgresql://idstudio:idstudio_dev_pw@localhost:5432/idstudio?schema=public
REDIS_URL=redis://localhost:6379

# ── Docker Compose deployment ────────────────────────────────────────────────
# Postgres credentials. Compose builds the app's DATABASE_URL from these.
POSTGRES_USER=idstudio
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=idstudio

# Public hostname Caddy serves + provisions TLS for. Use a real DNS name in prod.
# For purely local testing without a domain, set DOMAIN=localhost (self-signed).
DOMAIN=idstudio.example.com
# Email Let's Encrypt uses for cert expiry notices.
ACME_EMAIL=you@example.com

# MinIO (S3-compatible object storage for attachments — wired up in Phase 1).
MINIO_ROOT_USER=idstudio
MINIO_ROOT_PASSWORD=change-me-too-strong-password

# S3 (MinIO) access for card attachments.
# S3_ENDPOINT        = host the APP uses (Docker: http://minio:9000).
# S3_PUBLIC_ENDPOINT = host the BROWSER uses for presigned upload/download URLs.
#   In production this must be publicly reachable (e.g. https://files.your-domain
#   proxied to MinIO, or http://<host-ip>:9000). Defaults to S3_ENDPOINT.
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_BUCKET=idstudio
S3_ACCESS_KEY=idstudio
S3_SECRET_KEY=change-me-too-strong-password
S3_REGION=us-east-1
