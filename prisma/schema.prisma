// IDStudio — Instructional Designer Workspace
// Prisma 7 schema. Client is generated to src/generated/prisma (see generator).
// Phase 0 covers identity & tenancy only; feature models (boards, projects,
// storyboards, exams, LMS) are added in later phases.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MEMBER
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String?
  passwordHash String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  memberships  Membership[]
  assignedCards CardAssignee[]
  comments     Comment[]
}

model Workspace {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  members   Membership[]
  boards    Board[]
  projects  Project[]
}

// Role is per-workspace (on Membership), never global on User.
// All authorization resolves a user's role within the workspace owning a resource.
model Membership {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  role        Role      @default(MEMBER)
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

// ── Kanban (Phase 1) ─────────────────────────────────────────────────────────
// Ordering uses fractional-index strings (`position`): inserting between two
// items computes a key between their keys — a single-row update, no renumbering.

model Board {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  columns     Column[]
  labels      Label[]

  @@index([workspaceId])
}

model Column {
  id        String   @id @default(cuid())
  boardId   String
  name      String
  position  String
  createdAt DateTime @default(now())
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards     Card[]

  @@index([boardId, position])
}

model Card {
  id          String         @id @default(cuid())
  columnId    String
  title       String
  description String? // TipTap document, stored as JSON string
  dueDate     DateTime?
  position    String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  column      Column          @relation(fields: [columnId], references: [id], onDelete: Cascade)
  labels       CardLabel[]
  assignees    CardAssignee[]
  checklist    ChecklistItem[]
  comments     Comment[]
  attachments  Attachment[]
  deliverables Deliverable[]

  @@index([columnId, position])
}

model Attachment {
  id           String   @id @default(cuid())
  cardId       String
  workspaceId  String
  fileName     String
  mimeType     String
  sizeBytes    Int
  storageKey   String   @unique
  uploadedById String
  createdAt    DateTime @default(now())
  card         Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
}

// ── Project management (Phase 2) ─────────────────────────────────────────────

enum Methodology {
  ADDIE
  SAM
  CUSTOM
}

model Project {
  id          String      @id @default(cuid())
  workspaceId String
  name        String
  description String?
  methodology Methodology @default(ADDIE)
  status      String      @default("active") // active / on_hold / completed
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  phases       Phase[]
  deliverables Deliverable[]
  milestones   Milestone[]

  @@index([workspaceId])
}

model Phase {
  id           String        @id @default(cuid())
  projectId    String
  name         String
  position     String
  status       String        @default("not_started") // not_started / in_progress / done
  startDate    DateTime?
  endDate      DateTime?
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deliverables Deliverable[]

  @@index([projectId, position])
}

model Deliverable {
  id        String   @id @default(cuid())
  projectId String
  phaseId   String?
  cardId    String?
  name      String
  type      String   @default("other") // storyboard / course / assessment / job_aid / video / document / other
  status    String   @default("not_started") // not_started / in_progress / in_review / complete
  position  String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase     Phase?   @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  card      Card?    @relation(fields: [cardId], references: [id], onDelete: SetNull)

  @@index([projectId, position])
}

model Milestone {
  id          String    @id @default(cuid())
  projectId   String
  name        String
  dueDate     DateTime?
  completedAt DateTime?
  position    String
  createdAt   DateTime  @default(now())
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, position])
}

model ChecklistItem {
  id       String  @id @default(cuid())
  cardId   String
  text     String
  done     Boolean @default(false)
  position String
  card     Card    @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId, position])
}

model Comment {
  id        String   @id @default(cuid())
  cardId    String
  authorId  String
  body      String
  createdAt DateTime @default(now())
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([cardId, createdAt])
}

model Label {
  id      String      @id @default(cuid())
  boardId String
  name    String
  color   String // hex like "#ef4444"
  board   Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards   CardLabel[]

  @@index([boardId])
}

model CardLabel {
  cardId  String
  labelId String
  card    Card  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label   Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([cardId, labelId])
  @@index([labelId])
}

model CardAssignee {
  cardId String
  userId String
  card   Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([cardId, userId])
  @@index([userId])
}
