// IDStudio — Instructional Designer Workspace
// Prisma 7 schema. Client is generated to src/generated/prisma (see generator).
// Phase 0 covers identity & tenancy only; feature models (boards, projects,
// storyboards, exams, LMS) are added in later phases.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MEMBER
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String?
  passwordHash String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  memberships  Membership[]
  assignedCards CardAssignee[]
  comments     Comment[]
  reviewCycles ReviewCycle[] @relation("ReviewReviewer")
  requestedReviews ReviewCycle[] @relation("ReviewRequester")
  timeEntries  TimeEntry[]
  groupMemberships GroupMembership[]
}

model Workspace {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  members     Membership[]
  boards      Board[]
  projects    Project[]
  storyboards Storyboard[]
  groups      Group[]
}

// Role is per-workspace (on Membership), never global on User.
// All authorization resolves a user's role within the workspace owning a resource.
model Membership {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  role        Role      @default(MEMBER)
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

// ── Kanban (Phase 1) ─────────────────────────────────────────────────────────
// Ordering uses fractional-index strings (`position`): inserting between two
// items computes a key between their keys — a single-row update, no renumbering.

model Board {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  columns     Column[]
  labels      Label[]
  groupAccess BoardGroup[]

  @@index([workspaceId])
}

model Column {
  id        String   @id @default(cuid())
  boardId   String
  name      String
  position  String
  createdAt DateTime @default(now())
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards     Card[]

  @@index([boardId, position])
}

model Card {
  id          String         @id @default(cuid())
  columnId    String
  title       String
  description String? // TipTap document, stored as JSON string
  dueDate     DateTime?
  position    String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  column      Column          @relation(fields: [columnId], references: [id], onDelete: Cascade)
  labels       CardLabel[]
  assignees    CardAssignee[]
  checklist    ChecklistItem[]
  comments     Comment[]
  attachments  Attachment[]
  deliverables Deliverable[]

  @@index([columnId, position])
}

model Attachment {
  id           String   @id @default(cuid())
  cardId       String
  workspaceId  String
  fileName     String
  mimeType     String
  sizeBytes    Int
  storageKey   String   @unique
  uploadedById String
  createdAt    DateTime @default(now())
  card         Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
}

// ── Project management (Phase 2) ─────────────────────────────────────────────

enum Methodology {
  ADDIE
  SAM
  CUSTOM
}

model Project {
  id          String      @id @default(cuid())
  workspaceId String
  name        String
  description String?
  methodology Methodology @default(ADDIE)
  status      String      @default("active") // active / on_hold / completed
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  phases       Phase[]
  deliverables Deliverable[]
  milestones   Milestone[]
  timeEntries  TimeEntry[]
  groupAccess  ProjectGroup[]

  @@index([workspaceId])
}

model Phase {
  id           String        @id @default(cuid())
  projectId    String
  name         String
  position     String
  status       String        @default("not_started") // not_started / in_progress / done
  startDate    DateTime?
  endDate      DateTime?
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deliverables Deliverable[]

  @@index([projectId, position])
}

model Deliverable {
  id        String   @id @default(cuid())
  projectId String
  phaseId   String?
  cardId    String?
  name      String
  type      String   @default("other") // storyboard / course / assessment / job_aid / video / document / other
  status    String   @default("not_started") // not_started / in_progress / in_review / complete
  position  String
  createdAt DateTime @default(now())
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase        Phase?        @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  card         Card?         @relation(fields: [cardId], references: [id], onDelete: SetNull)
  reviewCycles ReviewCycle[]
  timeEntries  TimeEntry[]
  storyboard   Storyboard?

  @@index([projectId, position])
}

model ReviewCycle {
  id            String      @id @default(cuid())
  deliverableId String
  reviewerId    String
  requestedById String? // who set up the review (null for legacy rows)
  round         Int
  status        String      @default("requested") // requested / in_review / changes_requested / approved
  dueDate       DateTime?
  feedback      String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deliverable   Deliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  reviewer      User        @relation("ReviewReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  requestedBy   User?       @relation("ReviewRequester", fields: [requestedById], references: [id], onDelete: SetNull)

  @@index([deliverableId])
  @@index([reviewerId])
  @@index([requestedById])
}

model TimeEntry {
  id            String       @id @default(cuid())
  projectId     String
  deliverableId String?
  userId        String
  minutes       Int
  note          String?
  loggedFor     DateTime
  createdAt     DateTime     @default(now())
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deliverable   Deliverable? @relation(fields: [deliverableId], references: [id], onDelete: SetNull)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Milestone {
  id          String    @id @default(cuid())
  projectId   String
  name        String
  dueDate     DateTime?
  completedAt DateTime?
  position    String
  createdAt   DateTime  @default(now())
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, position])
}

// ── Storyboarding (Phase 3) ──────────────────────────────────────────────────
// A storyboard is workspace-scoped (like a Board) and may optionally be linked to
// a project Deliverable of type "storyboard". It holds an ordered list of Screens.

model Storyboard {
  id            String       @id @default(cuid())
  workspaceId   String
  deliverableId String?      @unique
  title         String
  description   String?
  status        String       @default("draft") // draft / in_review / approved
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deliverable   Deliverable? @relation(fields: [deliverableId], references: [id], onDelete: SetNull)
  screens       Screen[]
  groupAccess   StoryboardGroup[]

  @@index([workspaceId])
}

model Screen {
  id               String     @id @default(cuid())
  storyboardId     String
  title            String
  screenType       String     @default("content") // intro / content / video / knowledge_check / interaction / assessment / summary
  position         String
  onScreenText     String? // TipTap document, stored as JSON string
  narration        String? // TipTap document — voiceover / audio script
  visualNotes      String? // TipTap document — visuals, media, layout
  interactionNotes String? // TipTap document — interactions, branching, programming
  developerNotes   String? // TipTap document — production / developer notes
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  storyboard       Storyboard @relation(fields: [storyboardId], references: [id], onDelete: Cascade)

  @@index([storyboardId, position])
}

model ChecklistItem {
  id       String  @id @default(cuid())
  cardId   String
  text     String
  done     Boolean @default(false)
  position String
  card     Card    @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId, position])
}

model Comment {
  id        String   @id @default(cuid())
  cardId    String
  authorId  String
  body      String
  createdAt DateTime @default(now())
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([cardId, createdAt])
}

model Label {
  id      String      @id @default(cuid())
  boardId String
  name    String
  color   String // hex like "#ef4444"
  board   Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards   CardLabel[]

  @@index([boardId])
}

model CardLabel {
  cardId  String
  labelId String
  card    Card  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label   Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([cardId, labelId])
  @@index([labelId])
}

model CardAssignee {
  cardId String
  userId String
  card   Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([cardId, userId])
  @@index([userId])
}

// ── Groups & access control ──────────────────────────────────────────────────
// A Group is a named set of workspace members. Access is DEFAULT-OPEN: a board /
// storyboard / project is visible to every workspace member UNTIL it is shared
// with one or more groups, after which only members of those groups (plus
// workspace ADMINs, who always have access) can see it. See src/lib/authz.ts.

model Group {
  id          String            @id @default(cuid())
  workspaceId String
  name        String
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members     GroupMembership[]
  boards      BoardGroup[]
  storyboards StoryboardGroup[]
  projects    ProjectGroup[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model GroupMembership {
  groupId String
  userId  String
  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@index([userId])
}

// Resource ↔ group access grants. Presence of any row restricts the resource to
// the granted groups; absence of rows leaves it open to all workspace members.

model BoardGroup {
  boardId String
  groupId String
  board   Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([boardId, groupId])
  @@index([groupId])
}

model StoryboardGroup {
  storyboardId String
  groupId      String
  storyboard   Storyboard @relation(fields: [storyboardId], references: [id], onDelete: Cascade)
  group        Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([storyboardId, groupId])
  @@index([groupId])
}

model ProjectGroup {
  projectId String
  groupId   String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  group     Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([projectId, groupId])
  @@index([groupId])
}
